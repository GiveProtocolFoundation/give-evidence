{
  "name": "give-evidence",
  "version": "0.0.0",
  "private": true,
  "description": "Funder-side accountability infrastructure — v0 wedge for Give Protocol Foundation.",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.12.0",
  "sideEffects": false,
  "scripts": {
    "build": "remix vite:build",
    "dev": "remix vite:dev",
    "start": "remix-serve ./build/server/index.js",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@remix-run/node": "2.15.0",
    "@remix-run/react": "2.15.0",
    "@remix-run/serve": "2.15.0",
    "isbot": "5.1.17",
    "pino": "9.5.0",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@remix-run/dev": "2.15.0",
    "@types/node": "20.16.10",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "autoprefixer": "10.4.20",
    "postcss": "8.4.49",
    "tailwindcss": "3.4.14",
    "typescript": "5.6.3",
    "vite": "5.4.11",
    "vite-tsconfig-paths": "5.1.3",
    "vitest": "2.1.9"
  }
}
