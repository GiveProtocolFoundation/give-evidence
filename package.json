{
  "name": "give-evidence",
  "version": "0.0.0",
  "private": true,
  "description": "Funder-side accountability infrastructure — v0 wedge for Give Protocol Foundation.",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@types/node": "25.6.0",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}
