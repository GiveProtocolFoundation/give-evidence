{
  "name": "give-evidence-spike-remix",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "remix vite:build",
    "dev": "remix vite:dev",
    "start": "remix-serve ./build/server/index.js",
    "typecheck": "tsc",
    "test": "vitest run",
    "check:deps": "depcheck",
    "db:generate:sqlite": "drizzle-kit generate --config=drizzle.sqlite.config.ts",
    "db:generate:postgres": "drizzle-kit generate --config=drizzle.postgres.config.ts",
    "db:generate": "pnpm db:generate:sqlite && pnpm db:generate:postgres",
    "db:migrate:sqlite": "tsx src/db/cli/migrate-sqlite.ts",
    "db:migrate:postgres": "tsx src/db/cli/migrate-postgres.ts",
    "db:check:sqlite": "drizzle-kit check --config=drizzle.sqlite.config.ts",
    "db:check:postgres": "drizzle-kit check --config=drizzle.postgres.config.ts",
    "import:round": "tsx scripts/import-round.ts"
  },
  "dependencies": {
    "@remix-run/node": "^2.17.4",
    "@remix-run/react": "^2.17.3",
    "@remix-run/serve": "^2.17.4",
    "better-sqlite3": "^11.5.0",
    "drizzle-orm": "^0.45.2",
    "isbot": "^5.1.17",
    "pino": "^9.5.0",
    "postgres": "^3.4.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@remix-run/dev": "^2.17.4",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^25.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "depcheck": "^1.4.7",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.6"
  }
}
